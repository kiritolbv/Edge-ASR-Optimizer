def initialise_state() -> None:
    defaults = {"screen": "record", "result": None, "quiz": None, "score": None, "recording": None}
    for key, value in defaults.items():
        st.session_state.setdefault(key, value)


@st.cache_resource(show_spinner=False)
def whisper_model() -> whisper.Whisper:
    return whisper.load_model("base")


def make_quiz(movie: str) -> list[dict[str, object]]:
    title = movie if movie and movie != "Inconnu" else "Le Parrain"
    questions = [
        ("What is the movie title?", title, ["Goodfellas", "Once Upon a Time in America"]),
        ("What year was it released?", "1972", ["1970", "1974"]),
        ("Which actor says this line?", "Marlon Brando", ["Al Pacino", "Robert De Niro"]),
    ]
    quiz = []
    for label, answer, alternatives in questions:
        choices = [answer, *alternatives]
        random.shuffle(choices)
        quiz.append({"label": label, "answer": answer, "choices": choices})
    return quiz


def save_recording(recording: st.runtime.uploaded_file_manager.UploadedFile) -> Path:
    recordings = ROOT / "enregistrement_voix"
    recordings.mkdir(exist_ok=True)
    target = recordings / f"joueur_{datetime.now():%Y%m%d_%H%M%S}.wav"
    target.write_bytes(recording.getvalue())
    return target


def execute_pipeline(recording: st.runtime.uploaded_file_manager.UploadedFile, status: st.status) -> dict[str, object]:
    source = save_recording(recording)
    run_dir = ROOT / "interface_output" / source.stem
    run_dir.mkdir(parents=True, exist_ok=True)
    optimizer = AudioMLOptimizer(PipelineConfig())

    status.update(label="Preparing your audioâ€¦", state="running")
    prepared_audio = run_dir / "input_asr.wav"
    optimizer.process_file(source, prepared_audio)

    status.update(label="Whisper is analysing your lineâ€¦", state="running")
    text = transcribe_wav(whisper_model(), prepared_audio, "en", run_dir / "input.srt")
    (run_dir / "transcription.txt").write_text(text + "\n", encoding="utf-8")
    if not text:
        raise RuntimeError("No spoken line was detected.")

    status.update(label="Searching for three clipsâ€¦", state="running")
    ensure_playwright_browser()
    clips = get_all_clips(text, number=3, start_pos=0)
    if not clips:
        raise RuntimeError("No clip was found for this line.")

    status.update(label="Preparing clips and subtitlesâ€¦", state="running")
    completed: list[dict[str, object]] = []
    for index, clip in enumerate(clips, start=1):
        process_clip(clip, index, run_dir, optimizer, whisper_model(), "en")
        video = run_dir / f"{index:02d}_{clean_name(clip['movie'])}_subtitled.mp4"
        if video.exists():
            completed.append({"clip": clip, "video": video})
    if not completed:
        raise RuntimeError("Clips were found, but no final MP4 could be created.")
    status.update(label="Line found!", state="complete")
    return {"text": text, "clips": completed, "directory": run_dir}


def clean_name(value: str) -> str:
    from playphrase_original import clean_filename

    return clean_filename(value) or "inconnu"


def header(title: str) -> None:
    st.markdown(
        f"<div class='topbar'><div class='icon'>â˜°</div><div class='brand'><span style='color:#ef443c;border-bottom:2px solid #ef443c'>CINÃ‰</span>REPLY</div><div class='icon'>â™¡</div></div><div class='screen-title'>{title}</div>",
        unsafe_allow_html=True,
    )


def record_screen() -> None:
    header("Say a movie line")
    left, right = st.columns((1.15, .85), gap="large")
    with left:
        st.markdown("<div class='hero'>SAY A LINE,<br><em>WE FIND THE MOVIE.</em></div>", unsafe_allow_html=True)
        st.markdown("<div class='subtitle'>Tap the microphone and speak naturally.</div>", unsafe_allow_html=True)
        st.markdown("<div class='orbital'></div>", unsafe_allow_html=True)
        recording = st.audio_input("Tap to speak", label_visibility="collapsed")
        st.markdown("<div class='wave'>ã€°ã€°ã€°ã€°ã€°</div><div class='mic-copy'>Tap to speak</div><div class='subtitle'>Record your favourite movie line</div>", unsafe_allow_html=True)
    with right:
        st.markdown("""<div class='panel desktop-side'><div class='eyebrow'>How it works</div>
          <div class='step'><b>1.</b><div>Speak<br><small>Say a movie line.</small></div></div>
          <div class='step'><b>2.</b><div>We search<br><small>We find the matching clip.</small></div></div>
          <div class='step'><b>3.</b><div>Play<br><small>Guess the movie and score.</small></div></div></div>""", unsafe_allow_html=True)
    if recording and st.button("ANALYSE MY LINE"):
        st.session_state.recording = recording
        st.session_state.screen = "processing"
        st.rerun()


def processing_screen() -> None:
    header("Searching")
    st.markdown("<div class='hero'>FINDING<br><em>THE PERFECT LINEâ€¦</em></div><div class='subtitle'>Your recording is being analysed. This may take a moment.</div><div class='search-orb'>âŒ•</div><div class='wave'>ã€°ã€°ã€°ã€°ã€°</div>", unsafe_allow_html=True)
    time.sleep(0.7)
    try:
        with st.status("Initialisationâ€¦", expanded=True) as status:
            st.session_state.result = execute_pipeline(st.session_state.recording, status)
        st.session_state.screen = "result"
        st.rerun()
    except Exception as error:
        st.error(str(error))
        if st.button("START AGAIN"):
            st.session_state.screen = "record"
            st.rerun()


def result_screen() -> None:
    header("Line found")
    result = st.session_state.result
    first = result["clips"][0]
    left, right = st.columns((1.25, .75), gap="large")
    with left:
        st.markdown("<div class='hero' style='font-size:1.7rem'>Here is the clip<br>matching your line:</div>", unsafe_allow_html=True)
        st.markdown("<div class='result-video'>", unsafe_allow_html=True)
        st.video(first["video"].read_bytes(), format="video/mp4")
        st.markdown("</div>", unsafe_allow_html=True)
    with right:
        st.markdown(f"<div class='panel desktop-side'><div class='eyebrow' style='text-align:center'>Your line</div><div class='quote'>{result['text']}</div></div>", unsafe_allow_html=True)
    if st.button("CONTINUE TO THE QUIZ"):
        st.session_state.quiz = make_quiz(first["clip"]["movie"])
        st.session_state.screen = "quiz"
        st.rerun()


def quiz_screen() -> None:
    header("The challenge")
    current_score = st.session_state.score or 0
    st.markdown(f"<div class='score'>{current_score}/3<br><small style='color:#a4a4a4;font-size:.65rem'>SCORE</small></div><div class='hero' style='font-size:1.7rem'>YOUR TURN</div><div class='quiz-progress'></div>", unsafe_allow_html=True)
    answers: list[str] = []
    for index, question in enumerate(st.session_state.quiz, start=1):
        st.markdown(f"<div class='panel'><b>{index}. {question['label']}</b></div>", unsafe_allow_html=True)
        answers.append(st.radio("Answer", question["choices"], key=f"quiz_{index}", label_visibility="collapsed"))
    if st.button("CHECK MY ANSWERS"):
        st.session_state.score = sum(answer == question["answer"] for answer, question in zip(answers, st.session_state.quiz))
        st.rerun()
    if st.session_state.score is not None:
        st.success(f"Score: {st.session_state.score}/3")
        if st.button("NEW LINE"):
            st.session_state.screen = "record"
            st.session_state.result = None
            st.session_state.quiz = None
            st.session_state.score = None
            st.session_state.recording = None
            st.rerun()


def main() -> None:
    inject_style()
    initialise_state()
    screen = st.session_state.screen
    if screen == "record":
        record_screen()
    elif screen == "processing":
        processing_screen()
    elif screen == "result":
        result_screen()
    else:
        quiz_screen()


if __name__ == "__main__":
    main()




